        </visual>
      </link>
    </model>
    <!-- Main north wall left (along X): offset Y by -0.075 → y=0.875 -->
    <model name="feat_5">
      <static>true</static>
      <pose>-6.2 0.89 0.125 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.3 0.12 0.25</size></box></geometry>
