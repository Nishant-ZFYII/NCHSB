    <!-- East inner wall (protrude -X into right corridor) -->
    <model name="feat_22">
      <static>true</static>
      <pose>8.175 -2.0 0.125 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.12 0.40 0.25</size></box></geometry></collision>
