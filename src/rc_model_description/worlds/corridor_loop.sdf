    </model>
    <model name="feat_10">
      <static>true</static>
      <pose>2.9 4.825 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.15 0.15 0.5</size></box></geometry></collision>
        <visual name="visual">
